{
  "name": "@g-motion/webgpu",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./compute": {
      "types": "./dist/compute.d.ts",
      "import": "./dist/compute.js",
      "require": "./dist/compute.cjs"
    },
    "./buffer": {
      "types": "./dist/buffer.d.ts",
      "import": "./dist/buffer.js",
      "require": "./dist/buffer.cjs"
    },
    "./wgsl": {
      "types": "./dist/wgsl.d.ts",
      "import": "./dist/wgsl.js",
      "require": "./dist/wgsl.cjs"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js",
      "require": "./dist/engine.cjs"
    },
    "./shaders": {
      "types": "./dist/shaders.d.ts",
      "import": "./dist/shaders.js",
      "require": "./dist/shaders.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "vitest run",
    "bench": "pnpm --filter @g-motion/benchmark bench"
  },
  "dependencies": {
    "@g-motion/shared": "workspace:*"
  },
  "devDependencies": {
    "@g-motion/benchmark": "workspace:*",
    "@rslib/core": "workspace:*",
    "@types/node": "workspace:*",
    "typescript": "workspace:*",
    "vitest": "workspace:*",
    "@webgpu/types": "^0.1.67"
  }
}
