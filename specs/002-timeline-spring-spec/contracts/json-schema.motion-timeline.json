{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://g-motion.dev/schemas/motion-timeline.json",
  "title": "G-Motion Timeline Schema",
  "type": "object",
  "properties": {
    "motion": {
      "type": "object",
      "properties": {
        "id": { "type": ["string", "number"] },
        "tracks": { "type": "array", "items": { "$ref": "#/definitions/Track" } },
        "timeline": { "$ref": "#/definitions/Timeline" }
      },
      "required": ["tracks", "timeline"]
    }
  },
  "required": ["motion"],
  "definitions": {
    "Timeline": {
      "type": "object",
      "properties": {
        "currentTime": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "minimum": 0 },
        "fps": { "type": "number", "minimum": 1 }
      },
      "required": ["currentTime", "duration", "fps"]
    },
    "Track": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "property": { "type": "string" },
        "marks": { "type": "array", "items": { "$ref": "#/definitions/Mark" } },
        "defaults": { "$ref": "#/definitions/TrackDefaults" }
      },
      "required": ["property", "marks"]
    },
    "TrackDefaults": {
      "type": "object",
      "properties": {
        "interp": { "$ref": "#/definitions/Interp" },
        "spring": { "$ref": "#/definitions/SpringConfig" },
        "inertia": { "$ref": "#/definitions/InertiaConfig" },
        "roving": { "type": "boolean" }
      }
    },
    "Mark": {
      "type": "object",
      "properties": {
        "time": { "type": "number", "minimum": 0 },
        "to": { "type": ["number", "object"] },
        "duration": { "type": "number", "minimum": 0 },
        "interp": { "$ref": "#/definitions/Interp" },
        "spring": { "$ref": "#/definitions/SpringConfig" },
        "inertia": { "$ref": "#/definitions/InertiaConfig" }
      },
      "required": ["to"]
    },
    "Interp": {
      "type": "string",
      "enum": ["linear", "bezier", "hold", "spring", "inertia", "autoBezier"]
    },
    "SpringConfig": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["physics", "duration"] },
        "stiffness": { "type": "number", "minimum": 0 },
        "damping": { "type": "number", "minimum": 0 },
        "mass": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "minimum": 0 },
        "initialVelocity": { "type": "number" }
      },
      "required": ["mode"]
    },
    "InertiaConfig": {
      "type": "object",
      "properties": {
        "deceleration": { "type": "number", "minimum": 0 },
        "snapTo": { "oneOf": [ { "type": "number" }, { "type": "object", "properties": { "threshold": { "type": "number", "minimum": 0 }, "target": { "type": ["number", "object"] } }, "required": ["threshold"] } ] },
        "initialVelocity": { "type": "number" }
      }
    }
  }
}
