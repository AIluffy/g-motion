{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", "build/**"],
      "inputs": ["src/**", "rslib.config.ts", "tsconfig.json", "package.json"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true
    },
    "format": {
      "cache": false
    },
    "test": {
      "outputs": [],
      "cache": true
    },
    "type-check": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "bench": {
      "outputs": [],
      "cache": false,
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalDependencies": [
    "pnpm-lock.yaml",
    ".npmrc",
    "tsconfig.json"
  ]
}
